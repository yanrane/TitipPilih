generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Category {
  id          String    @id @default(cuid())
  slug        String    @unique
  label       String
  description String    @db.Text
  products    Product[]
  reviews     Review[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Kurator {
  id          String   @id @default(cuid())
  name        String
  role        String
  bio         String   @db.Text
  initials    String   @db.VarChar(2)
  accentColor String   // Tailwind CSS class string e.g. "text-blue-400 bg-blue-500/20 border-blue-500/30"
  categories  String[] // display tags
  reviews     Review[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Product {
  id           String    @id @default(cuid())
  slug         String    @unique
  title        String
  image        String    @default("")
  categorySlug String
  category     Category  @relation(fields: [categorySlug], references: [slug])
  rating       Float     // 0–10
  priceMin     Int       // in IDR
  priceMax     Int?      // in IDR, nullable
  affiliateUrl String
  trending     Boolean   @default(false)
  review       Review?
  affiliateClicks AffiliateClick[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Review {
  id           String   @id @default(cuid())
  slug         String   @unique
  title        String
  categorySlug String
  category     Category @relation(fields: [categorySlug], references: [slug])
  productId    String?  @unique
  product      Product? @relation(fields: [productId], references: [id])
  rating       Float    // 0–10
  priceMin     Int      // in IDR
  priceMax     Int?     // in IDR, nullable
  affiliateUrl String
  kuratorId    String
  kurator      Kurator  @relation(fields: [kuratorId], references: [id])
  tanggal      DateTime
  estimasiBaca Int      // menit
  pros         String[]
  cons         String[]
  published    Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model AffiliateClick {
  id          String   @id @default(cuid())
  productId   String
  productSlug String
  source      String?  @db.VarChar(64)
  campaign    String?  @db.VarChar(128)
  contentId   String?  @db.VarChar(128)
  referrer    String?  @db.Text
  userAgent   String?  @db.Text
  ipHash      String?  @db.VarChar(128)
  createdAt   DateTime @default(now())

  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, createdAt])
  @@index([productSlug, createdAt])
  @@index([source, createdAt])
  @@index([campaign, createdAt])
  @@index([createdAt])
}

model DonationWeek {
  id              String      @id @default(cuid())
  periode         String      // "1 April – 7 April 2026"
  periodeStart    DateTime
  periodeEnd      DateTime
  totalKomisi     Int         // IDR
  totalDisisihkan Int         // IDR
  persentase      Int         @default(15) // %
  recipients      Recipient[]
  createdAt       DateTime    @default(now())
}

model Recipient {
  id             String       @id @default(cuid())
  donationWeekId String
  donationWeek   DonationWeek @relation(fields: [donationWeekId], references: [id], onDelete: Cascade)
  foto           String       @default("")
  inisial        String       // "Bpk. S." — NO full name (privacy)
  wilayah        String       // kelurahan/kota only — NO full address
  nominal        Int          // IDR
  tanggal        DateTime
  createdAt      DateTime     @default(now())
}
model AffiliateClick {
  id          String   @id @default(cuid())
  productId   String
  productSlug String
  source      String?
  campaign    String?
  contentId   String?
  referrer    String?
  userAgent   String?
  ipHash      String?
  createdAt   DateTime @default(now())
}
